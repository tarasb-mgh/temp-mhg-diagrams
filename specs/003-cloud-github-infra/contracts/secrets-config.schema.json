{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secrets Configuration",
  "description": "Master list of secrets managed in Google Secret Manager. Used by setup-secrets.sh to ensure all secrets exist.",
  "type": "object",
  "required": ["project_id", "secrets"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "GCP project ID (e.g., mental-help-global-25)"
    },
    "iam_members": {
      "type": "array",
      "description": "Default IAM members that get secretAccessor role on all secrets",
      "items": {
        "type": "string",
        "description": "IAM member (e.g., serviceAccount:123-compute@developer.gserviceaccount.com)"
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SecretDefinition"
      }
    }
  },
  "definitions": {
    "SecretDefinition": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Secret name in Secret Manager",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "description": "Human-readable purpose of this secret"
        },
        "auto_generate": {
          "type": "boolean",
          "description": "Generate a random value on first creation",
          "default": false
        },
        "generate_length": {
          "type": "integer",
          "description": "Length of auto-generated value",
          "default": 32,
          "minimum": 8,
          "maximum": 128
        },
        "github_secret_name": {
          "type": "string",
          "description": "Corresponding GitHub Secret name when synced"
        },
        "github_transform": {
          "type": "string",
          "description": "Transformation to apply when syncing to GitHub (e.g., database_url constructs a connection string)",
          "enum": ["none", "database_url"]
        },
        "iam_members": {
          "type": "array",
          "description": "Additional IAM members specific to this secret",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
